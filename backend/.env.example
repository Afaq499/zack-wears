PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/zack-wears
JWT_SECRET=change-this-to-a-long-random-string
PUBLIC_URL=http://localhost:4000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=zack-wears-bucket
S3_PUBLIC_BASE_URL=https://zack-wears-bucket.s3.us-east-1.amazonaws.com
# Set to "false" if your bucket uses "Bucket owner enforced" (no ACLs). Then add an S3 bucket policy allowing s3:GetObject on arn:aws:s3:::YOUR_BUCKET/products/* so image URLs work in the browser.
# S3_UPLOAD_PUBLIC_ACL=false
# Use the exact origin shown in the browser (localhost vs 127.0.0.1). The API also accepts the alias host automatically in development.
STOREFRONT_ORIGIN=http://localhost:3000
# When NODE_ENV is not production, any http://localhost:* or http://127.0.0.1:* origin is allowed (covers Vite using 5174, etc.).
ADMIN_ORIGIN=http://localhost:5173
ADMIN_EMAIL=admin@zackwears.local
ADMIN_PASSWORD=change-me
